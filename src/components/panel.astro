---
import { ShoppingCartIcon } from "@animateicons/react/lucide";
import "../styles/panel.css";
import { Image } from "astro:assets";
import triples from "../assets/triples.png";
import donas from "../assets/donas.jpg";
import "../styles/poll.css";
import pulpitos from "../assets/pulpitos.jpg";
import CircleCheckIcon from "./CircleCheckIcon";
---

<section class="panel">
  <div class="box">
    <Image src={triples} alt="Product" class="box-image" loading="eager"/>
    <div class="price-box" data-product="Triples" data-price="1.50">
        <div class="stock">
            <span class="stock-label">Stock</span>
            <span class="stock-value">20</span>
        </div>
        <div class="price-container">
          <span class="price-label">
            <span class="seller">CHICATEJA</span>
            <span class="product">TRIPLES</span>
          </span>
          <span class="price">PEN 1.50</span>
        </div>
        <ShoppingCartIcon className="cart-icon" />
    </div>
  </div>

  <div class="box">
    <Image src={pulpitos} alt="Product" class="box-image" loading="eager"/>
    <div class="price-box" data-product="Pulpitos" data-price="1.50">
        <div class="stock">
            <span class="stock-label">Stock</span>
            <span class="stock-value">20</span>
        </div>
        <div class="price-container">
          <span class="price-label">
            <span class="seller">CHICATEJA</span>
            <span class="product">PULPITOS</span>
          </span>
          <span class="price">PEN 1.50</span>
        </div>
        <ShoppingCartIcon className="cart-icon" />
    </div>
  </div>

  <div class="box box--poll">
    <div class="next-week">

      <h3 class="poll-title">¡Elige dos para la siguiente semana!</h3>

      <div class="poll-grid">

        <div class="poll-column">
          <button class="poll-option" data-value="Producto 1">Pulpitos crujientes</button>
          <button class="poll-option" data-value="Producto 2">Bombitas azucaradas</button>
          <button class="poll-option" data-value="Producto 3">Rollitos de salchicha</button>
          <button class="poll-option" data-value="Producto 4">Triples</button>
        </div>

        <div class="poll-column">
          <button class="poll-option" data-value="Producto 5">Petipan de pollo</button>
          <button class="poll-option" data-value="Producto 6">Mini hamburguesas</button>
          <button class="poll-option" data-value="Producto 7">Chocotejas</button>
          <button class="poll-button">Enviar respuestas</button>
        </div>

      </div>

    </div>

    <div class="poll-success hidden">
      <p>Respuestas enviadas</p>
      <CircleCheckIcon size={50} className="text-white" client:load />
    </div>
    
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const options = document.querySelectorAll(".poll-option");
    const sendButton = document.querySelector(".poll-button");

    const pollBox = document.querySelector(".next-week") as HTMLElement;
    const success = document.querySelector(".poll-success") as HTMLElement;

    if (!pollBox || !success || !sendButton) return;

    const hasVoted = localStorage.getItem("voted");

    if (hasVoted) {
      pollBox.classList.add("hidden");
      success.classList.remove("hidden");
      return;
    }

    let selected: string[] = [];

    options.forEach((option) => {
      const el = option as HTMLElement;

      el.addEventListener("click", () => {
        const value = el.dataset.value;
        if (!value) return;

        if (selected.includes(value)) {
          selected = selected.filter((v) => v !== value);
          el.classList.remove("active");
          return;
        }

        if (selected.length >= 2) return;

        selected.push(value);
        el.classList.add("active");
      });
    });

    sendButton.addEventListener("click", () => {
      if (selected.length === 0) return;

      pollBox.style.transition = "0.4s ease";
      pollBox.style.opacity = "0";
      pollBox.style.transform = "translateY(10px)";

      setTimeout(() => {
        pollBox.classList.add("hidden");

        success.classList.remove("hidden");

        requestAnimationFrame(() => {
          success.classList.add("show");
        });
      }, 150);

      const formData = new FormData();
      formData.append("name", selected.join(", "));

      fetch("https://muddy-glade-4d62.2611010122.workers.dev/", {
        method: "POST",
        body: formData,
        headers: {
          "x-api-key": "poll_9xA7k2z_secure_key"
        }
      })
      .then(async (res) => {

        if (!res.ok && res.status !== 403) {
          throw new Error("Error en Worker");
        }

        pollBox.classList.add("hidden");
        success.classList.remove("hidden");

        requestAnimationFrame(() => {
          success.classList.add("show");
        });

        localStorage.setItem("voted", "true");

      })
      .catch((err) => {
        console.error("Fetch error:", err);

        pollBox.classList.add("hidden");
        success.classList.remove("hidden");

        localStorage.setItem("voted", "true");
      });

      selected = [];
      options.forEach((o) => o.classList.remove("active"));
    });

  });
</script>